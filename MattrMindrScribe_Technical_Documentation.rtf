  {\pard\sa60\f1\fs20 DATABASE_URL        = postgres://mattrmindr:***@localhost/mattrmindrscribe\par}
  {\pard\sa60\f1\fs20 JWT_SECRET          = <random string for JWT signing>\par}
  {\pard\sa60\f1\fs20 AWS_ACCESS_KEY_ID   = <IAM access key>\par}
  {\pard\sa60\f1\fs20 AWS_SECRET_ACCESS_KEY = <IAM secret key>\par}
  {\pard\sa60\f1\fs20 S3_BUCKET_NAME      = mattrmindrscribe-files\par}
  {\pard\sa60\f1\fs20 S3_REGION           = us-east-2\par}
  {\pard\sa60\f1\fs20 OPENAI_API_KEY      = <OpenAI API key for Whisper + GPT>\par}
  {\pard\sa60\f1\fs20 ANTHROPIC_API_KEY   = <Anthropic API key for Claude Opus>\par}
  {\pard\sa60\f1\fs20 ASSEMBLYAI_API_KEY  = <AssemblyAI API key for diarization>\par}
  {\pard\sa60\f1\fs20 ADMIN_ACCOUNTS      = [JSON array of \{email, password\} objects]\par}
  {\pard\sa60\f1\fs20 ADMIN_API_KEY       = <secret for admin restart endpoint>\par}
  {\pard\sa60\f1\fs20 NODE_ENV            = production\par}
  {\pard\sa60\f1\fs20 REPLIT_DEPLOYMENT   = 1   (triggers production mode in server)\par}

  {\pard\sb200\sa100\f0\fs28\b Optional:\b0\par}
  {\pard\sa60\f1\fs20 S3_PUBLIC_URL       = <custom S3 public URL if using CDN>\par}

