  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 server/routes/transcripts.ts\f0  \emdash  Permission checks on all transcript routes\par}
  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 server/routes/folders.ts\f0  \emdash  Permission checks on folder routes\par}
  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 server/routes/annotations.ts\f0  \emdash  Permission checks on annotation CRUD\par}
  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 server/middleware/auth.ts\f0  \emdash  Potentially add checkAccess helper\par}
  {\pard\fi-360\li720\sb0\sa200\f1\fs20\cf1 server/routes/shares.ts\f0  \emdash  New file for share CRUD routes\par}
