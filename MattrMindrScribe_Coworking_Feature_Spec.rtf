  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 src/components/layout/AppLayout.tsx\f0  \emdash  Handle shared folder/transcript navigation state\par}
  {\pard\fi-360\li720\sb0\sa60\f1\fs20\cf1 src/contexts/TranscriptContext.tsx\f0  \emdash  Store shared items, fetch "Shared with Me" data\par}
